+    def collapse_motions_to_static_pose(session: ClientSession) -> None:
+        """Collapse generated motions to a single repeated pose."""
+        for motion in session.motions.values():
+            if motion.length <= 0:
+                continue
+            pose_pos = motion.joints_pos[0:1].clone()
+            pose_rot = motion.joints_rot[0:1].clone()
+            pose_local_rot = motion.joints_local_rot[0:1].clone()
+            motion.joints_pos = pose_pos.repeat(motion.length, 1, 1)
+            motion.joints_rot = pose_rot.repeat(motion.length, 1, 1, 1)
+            motion.joints_local_rot = pose_local_rot.repeat(motion.length, 1, 1, 1)
+            if motion.foot_contacts is not None:
+                pose_contacts = motion.foot_contacts[0:1].clone()
+                motion.foot_contacts = pose_contacts.repeat(motion.length, 1)
+            motion.set_frame(0)
