+    def enqueue_generation(self, client: viser.ClientHandle, run: Callable[[], None]) -> tuple[int, bool]:
+        client_id = client.client_id
+        with self._generation_cv:
+            if self._active_generation_request is not None and self._active_generation_request.client_id == client_id:
+                raise RuntimeError("A generation is already running for this browser session.")
+
+            active_offset = 1 if self._active_generation_request is not None else 0
+            for idx, request in enumerate(self._generation_queue):
+                if request.client_id == client_id:
+                    self._generation_request_counter += 1
+                    self._generation_queue[idx] = GenerationRequest(
+                        request_id=self._generation_request_counter,
+                        client_id=client_id,
+                        run=run,
+                    )
+                    self._refresh_generation_button_states()
+                    return idx + active_offset, True
+
+            queue_position = len(self._generation_queue)
+            queue_position += active_offset
+            self._generation_request_counter += 1
+            self._generation_queue.append(
+                GenerationRequest(
+                    request_id=self._generation_request_counter,
+                    client_id=client_id,
+                    run=run,
+                )
+            )
+            self._refresh_generation_button_states()
+            self._generation_cv.notify()
+            return queue_position, False
+
+    def remove_generation_requests(self, client_id: int) -> None:
+        with self._generation_cv:
+            original_len = len(self._generation_queue)
+            self._generation_queue = [
+                request for request in self._generation_queue if request.client_id != client_id
+            ]
+            if len(self._generation_queue) != original_len:
+                self._refresh_generation_button_states()
+
+    def _refresh_generation_button_states(self) -> None:
+        queued_positions = {
+            request.client_id: idx + 1 for idx, request in enumerate(self._generation_queue)
+        }
+        active_client_id = None
+        if self._active_generation_request is not None:
+            active_client_id = self._active_generation_request.client_id
+
+        for client_id, session in list(self.client_sessions.items()):
+            button = session.gui_elements.gui_generate_button
+            if active_client_id == client_id:
+                button.label = "Generating..."
+                button.disabled = True
+                self._set_generation_status(
+                    session,
+                    "**Queue:** Your request is running now.",
+                )
+            elif client_id in queued_positions:
+                position = queued_positions[client_id]
+                button.label = f"Update Queued ({position})"
+                button.disabled = False
+                self._set_generation_status(
+                    session,
+                    f"**Queue:** Waiting in position {position}. Click **Generate** again to replace this queued job.",
+                )
+            elif button.label == "Choose Sample Before Generating":
+                self._set_generation_status(
+                    session,
+                    "**Queue:** Choose a sample before starting another generation.",
+                )
+            elif button.label == "Generate Disabled In Editing Mode":
+                self._set_generation_status(
+                    session,
+                    "**Queue:** Exit editing mode to generate again.",
+                )
+            else:
+                self._set_generation_status(
+                    session,
+                    "**Queue:** Ready. Editing remains available while queued jobs wait.",
+                )
+
+    def _generation_worker_loop(self) -> None:
+        while True:
+            with self._generation_cv:
+                while not self._generation_queue:
+                    self._generation_cv.wait()
+                request = self._generation_queue.pop(0)
+                self._active_generation_request = request
+                self._refresh_generation_button_states()
+
+            try:
+                if not self.client_active(request.client_id):
+                    continue
+                request.run()
+            except Exception:
+                traceback.print_exc()
+            finally:
+                with self._generation_cv:
+                    if self._active_generation_request is request:
+                        self._active_generation_request = None
+                    self._refresh_generation_button_states()
+
